# .env.example — copy to .env and fill in values

# App
APP_ENV=development               # development | production
DEMO_MODE=true                    # true to enable demo mode (RULE-09, RULE-25)
SECRET_KEY=gigshield-dev-secret-key-change-in-production  # JWT signing key (32+ chars)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3200,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3200

# Supabase (PostgreSQL)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres
DATABASE_URL=sqlite+aiosqlite:///gigshield.db
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
FIREBASE_PROJECT_ID=gigshield-dev

# Razorpay (TEST MODE ONLY — never production)
RAZORPAY_KEY_ID=rzp_test_XXXX
RAZORPAY_KEY_SECRET=XXXX
RAZORPAY_ACCOUNT_NUMBER=XXXXXXXXXXX

# ML Services
ML_PREMIUM_URL=http://localhost:8001
ML_FORECAST_URL=http://localhost:8002
ML_CNN_URL=http://localhost:8003
ML_TIMEOUT_SECONDS=10

# Scheduler
MSC_POLL_INTERVAL_MINUTES=30
FORECAST_UPDATE_CRON=0 20 * * 0   # Sunday 20:00 UTC
PREMIUM_DEDUCTION_CRON=30 0 * * 1  # Monday 00:30 UTC = 06:00 IST

# Logging
LOG_LEVEL=INFO

# Frontend (Vite)
VITE_API_BASE_URL=http://127.0.0.1:8002/api/v1
VITE_FIREBASE_API_KEY=XXXX
VITE_FIREBASE_AUTH_DOMAIN=gigshield-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=gigshield-dev
VITE_DEMO_MODE=true
